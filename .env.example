# ─────────────────────────────────────────────────────────────────────────────
#  GhostTip — environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Database (Postgres). For local dev: docker run --name pg -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghosttip

# Redis (ephemeral claim tokens, OAuth state, claim sessions).
# If unset, a process-local in-memory fallback is used — OK for dev, NOT for prod.
REDIS_URL=redis://localhost:6379

# ─── Solana ──────────────────────────────────────────────────────────────────
# Default cluster (also seeds the header switcher on first load).
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# HTTP RPC override for the active cluster. Strongly recommended for mainnet:
# the public `api.mainnet-beta.solana.com` is aggressively rate-limited and
# returns 403/429 to browser requests, which surfaces as a stuck "Loading
# balance…" spinner. Use Helius / QuickNode / Triton / Ankr etc.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Per-cluster overrides (used whichever cluster you switch to in the header).
# NEXT_PUBLIC_SOLANA_RPC_MAINNET=https://mainnet.helius-rpc.com/?api-key=...
# NEXT_PUBLIC_SOLANA_RPC_DEVNET=https://api.devnet.solana.com

# Optional server-side RPC override (for backend authority submissions).
SOLANA_RPC_URL=

# Backend authority keypair — the ONLY signer that can call claim_tip /
# refund_tip on the ghosttip program. Generate with:
#   solana-keygen new --no-bip39-passphrase --outfile ./authority.json
#   cat ./authority.json
# Then paste that JSON array (64 bytes) below. NEVER commit this value.
GHOSTTIP_AUTHORITY_KEYPAIR=

# ─── Anchor program ──────────────────────────────────────────────────────────
NEXT_PUBLIC_PROGRAM_ID=GhsTipQhNGUc8vN3WtNpe6VbMTaZh6UgJcy3q8LjMXyE

# If the ghosttip program isn't deployed yet, set this to `true` to skip
# on-chain claim/refund submission (the backend will emit mock signatures).
# This keeps the frontend demo working end-to-end without a live deployment.
ANCHOR_ON_CHAIN_DISABLED=true

# ─── Loyal Network SDK ───────────────────────────────────────────────────────
LOYAL_API_KEY=
LOYAL_NETWORK_URL=
# When true (or when LOYAL_API_KEY is missing), route through the mock rail.
NEXT_PUBLIC_LOYAL_MOCK=true

# ─── Twitter (X) OAuth ───────────────────────────────────────────────────────
# REQUIRED for the claim flow. Without real X creds, recipients cannot
# unlock their tips — there is no bypass.
#
# Setup:
#   1. https://developer.twitter.com/en/portal/dashboard → Create App
#   2. User authentication settings → "Type of App: Web App"
#   3. Callback URL: http://localhost:3000/api/auth/x/callback (dev)
#                    https://your-domain.com/api/auth/x/callback (prod)
#   4. OAuth 2.0 → enable; scopes: tweet.read, users.read
#
# CLIENT_SECRET is only required for confidential clients ("Web App, Automated
# App or Bot" style). If you chose "Native App" / "SPA" the flow is PKCE-only
# and the secret can be left blank.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Public base URL used when building redirect URIs. MUST match the callback
# URL you registered with Twitter, including protocol and port.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Cron ────────────────────────────────────────────────────────────────────
# Shared secret for /api/cron/expiry when not running on Vercel's cron.
CRON_SECRET=replace-me
