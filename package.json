{
  "name": "nextjs-anchor",
  "description": "Next.js, Tailwind, @solana/kit, Anchor vault program",
  "keywords": [
    "anchor",
    "kit",
    "nextjs",
    "react",
    "solana-kit",
    "tailwind",
    "typescript"
  ],
  "create-solana-dapp": {
    "rename": {
      "scaffold": {
        "to": "{{name}}",
        "paths": [
          "app"
        ]
      }
    }
  },
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "anchor-build": "cd anchor && anchor build",
    "anchor-test": "cd anchor && anchor test --skip-deploy",
    "build": "next build",
    "ci": "npm run build && npm run lint && npm run format:check",
    "codama:js": "codama run js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "setup": "npm run db:up && npm run db:migrate && npm run anchor-build && npm run codama:js",
    "start": "next start"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@loyal-labs/private-transactions": "^0.2.8",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.11.1",
    "@prisma/client": "^6",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana/kit": "^6.3.0",
    "@solana/kit-client-rpc": "^0.7.0",
    "@solana/kit-plugin-rpc": "^0.7.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-standard-features": "^1.3.0",
    "@solana/web3.js": "^1.98.4",
    "@wallet-standard/app": "^1.1.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "bs58": "^6.0.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "prisma": "^6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "swr": "^2.2.0",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "@tailwindcss/postcss": "^4",
    "@types/bs58": "^5.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "codama": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
